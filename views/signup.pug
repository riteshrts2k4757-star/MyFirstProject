extends base

block content
  .signup-form
    h2.heading-secondary Sign up

    form.form.form--signup
      .form__group
        label(for='name') Name
        input#name.form__input(type='text', placeholder='Your name', required)

      .form__group
        label(for='email') Email
        input#email.form__input(type='email', placeholder='you@example.com', required)

      .form__group
        label(for='password') Password
        input#password.form__input(type='password', placeholder='••••••••', required minlength='8')

      .form__group
        label(for='passwordConfirm') Confirm Password
        input#passwordConfirm.form__input(type='password', placeholder='••••••••', required minlength='8')

      .form__group
        button.btn.btn--green(type='submit') Sign up
